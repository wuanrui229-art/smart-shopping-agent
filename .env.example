# 推荐：Kimi 开放式聊天与任意品类推荐
LLM_PROVIDER=kimi
MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k3
MOONSHOT_FALLBACK_MODELS=kimi-k2.5
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# 可选：也可以改用 OpenAI；不配置任何密钥时自动进入离线演示模式
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# 可选服务配置
AI_GATEWAY_MODEL=openai/gpt-5.5
HOST=127.0.0.1
PORT=8000
RELOAD=0
